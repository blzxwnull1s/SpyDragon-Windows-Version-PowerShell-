# 24 — EXIF de imagen
function Tool-24 {
    Show-Section "24 - Metadatos EXIF de Imagen"
    Write-Color "  Ruta de la imagen (C:\...) o URL: " -FG White -NoNewline
    $IMG = Read-Host
    try {
        if ($IMG -match "^https?://") {
            # Descargar temporalmente
            $tmp = "$env:TEMP\fcb_img_tmp"
            Invoke-WebRequest -Uri $IMG -OutFile $tmp -TimeoutSec 10 -UseBasicParsing
            $IMG = $tmp
        }
        Add-Type -AssemblyName System.Drawing
        $bitmap = New-Object System.Drawing.Bitmap($IMG)
        $props = $bitmap.PropertyItems
        $EXIF_TAGS = @{
            0x010F = "Fabricante"
            0x0110 = "Modelo"
            0x0132 = "Fecha modificacion"
            0x9003 = "Fecha original"
            0x0112 = "Orientacion"
            0x8827 = "ISO"
            0x829A = "Velocidad obturacion"
            0x829D = "Apertura"
        }
        foreach ($prop in $props) {
            if ($EXIF_TAGS.ContainsKey($prop.Id)) {
                $val = [System.Text.Encoding]::ASCII.GetString($prop.Value).Trim("`0")
                Show-Result $EXIF_TAGS[$prop.Id] $val
            }
        }
        $bitmap.Dispose()
        if (-not $props) { Write-Color "  [*] No se encontraron metadatos EXIF" -FG Yellow }
    } catch {
        Write-Color "  [!] Error leyendo imagen: $_" -FG Red
    }
    Pause-Menu
}

