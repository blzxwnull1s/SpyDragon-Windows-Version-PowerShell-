# ── Colores ───────────────────────────────────────────────────
function Write-Color {
    param(
        [string]$Text,
        [ConsoleColor]$FG = [ConsoleColor]::White,
        [switch]$NoNewline
    )
    if ($NoNewline) {
        Write-Host $Text -ForegroundColor $FG -NoNewline
    } else {
        Write-Host $Text -ForegroundColor $FG
    }
}

function Pause-Menu {
    Write-Host ""
    Write-Color "  Presiona ENTER para continuar..." -FG DarkGray
    $null = Read-Host
}

function Show-Section {
    param([string]$Title)
    Clear-Host
    Write-Host ""
    Write-Color "  +==========================================+" -FG Cyan
    Write-Color "  |  $Title" -FG White
    Write-Color "  +==========================================+" -FG Cyan
    Write-Host ""
}

function Show-Result {
    param([string]$Label, [string]$Value)
    Write-Color "  > " -FG Green -NoNewline
    Write-Color "${Label}: " -FG White -NoNewline
    Write-Color $Value -FG Yellow
}

