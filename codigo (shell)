# 04 — DNS Lookup
function Tool-04 {
    Show-Section "04 - DNS Lookup"
    Write-Color "  Dominio: " -FG White -NoNewline
    $DOM = Read-Host
    foreach ($TYPE in @("A","AAAA","MX","NS","TXT","CNAME")) {
        Write-Color "  -- $TYPE --" -FG Cyan
        try {
            $records = Resolve-DnsName -Name $DOM -Type $TYPE -ErrorAction Stop
            foreach ($r in $records) {
                $val = if ($r.IPAddress) { $r.IPAddress } elseif ($r.NameExchange) { $r.NameExchange } elseif ($r.Strings) { $r.Strings -join " " } else { $r.ToString() }
                Write-Color "  > $val" -FG Yellow
            }
        } catch {
            Write-Color "  > (sin registros $TYPE)" -FG DarkGray
        }
    }
    Pause-Menu
}

