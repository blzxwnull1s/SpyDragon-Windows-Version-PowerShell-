        $tcp = New-Object System.Net.Sockets.TcpClient($DOM, 443)
        $ssl = New-Object System.Net.Security.SslStream($tcp.GetStream(), $false,
            { param($s,$c,$ch,$e) $true })
        $ssl.AuthenticateAsClient($DOM)
