# 15 — Cabecera de Email
function Tool-15 {
    Show-Section "15 - Analisis de Cabecera de Email"
    Write-Color "  Pega las cabeceras del email (linea vacia para terminar):" -FG Yellow
    Write-Host ""
    $lines = @()
    while ($true) {
        $line = Read-Host "  >"
        if ([string]::IsNullOrWhiteSpace($line)) { break }
        $lines += $line
    }
    $headers = $lines -join "`n"
    $patterns = @("Received:","From:","Reply-To:","X-Originating-IP:","Message-ID:")
    foreach ($line in $lines) {
        foreach ($p in $patterns) {
            if ($line -match $p) {
                Write-Color "  > $line" -FG Yellow
            }
        }
    }
    # Extraer IPs
    Write-Host ""
    Write-Color "  -- IPs detectadas --" -FG Cyan
    $ipRegex = '\b(\d{1,3}\.){3}\d{1,3}\b'
    $ips = [regex]::Matches($headers, $ipRegex) | ForEach-Object { $_.Value } | Sort-Object -Unique
    foreach ($ip in $ips) {
        Write-Color "  > $ip" -FG Green
    }
    Pause-Menu
}

