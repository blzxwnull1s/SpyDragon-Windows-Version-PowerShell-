        $cert2 = New-Object System.Security.Cryptography.X509Certificates.X509Certificate2($cert)
        Show-Result "Dominio"       $DOM
        Show-Result "Sujeto CN"     $cert2.Subject
        Show-Result "Emisor"        $cert2.Issuer
        Show-Result "Valido desde"  $cert2.NotBefore.ToString("yyyy-MM-dd")
        Show-Result "Valido hasta"  $cert2.NotAfter.ToString("yyyy-MM-dd")
        Show-Result "Thumbprint"    $cert2.Thumbprint
        $ssl.Close(); $tcp.Close()
    } catch {
        Write-Color "  [!] Error SSL: $_" -FG Red
    }
    Pause-Menu
}

