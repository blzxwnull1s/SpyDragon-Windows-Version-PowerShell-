# 08 — Puertos Abiertos
function Tool-08 {
    Show-Section "08 - Puertos Abiertos"
    Write-Color "  IP o host: " -FG White -NoNewline
    $HOST = Read-Host
    Write-Host ""
    $PORTS = @(21,22,23,25,53,80,110,143,443,445,3306,3389,5432,6379,8080,8443,27017)
    Write-Color "  Escaneando $($PORTS.Count) puertos en $HOST ..." -FG Yellow
    Write-Host ""
    foreach ($PORT in $PORTS) {
        $tcp = New-Object System.Net.Sockets.TcpClient
        try {
            $conn = $tcp.BeginConnect($HOST, $PORT, $null, $null)
            $wait = $conn.AsyncWaitHandle.WaitOne(500, $false)
            if ($wait -and $tcp.Connected) {
                Write-Color "  [+] Puerto $PORT ABIERTO" -FG Green
            }
            $tcp.Close()
        } catch { $tcp.Close() }
    }
    Write-Host ""
    Write-Color "  [*] Escaneo completado." -FG Cyan
    Pause-Menu
}

# 09 — Info SSL/TLS
function Tool-09 {
